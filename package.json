{
  "name": "@viewportai/viewport-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/relay",
    "integration"
  ],
  "scripts": {
    "daemon": "npm run build -w @viewportai/daemon && npm link -w @viewportai/daemon",
    "daemon:start": "vpd start --foreground",
    "daemon:status": "vpd status",
    "daemon:doctor": "vpd doctor",
    "daemon:stop": "vpd stop",
    "daemon:restart": "vpd restart",
    "relay": "bash ./scripts/dev-relay.sh",
    "daemon:test": "npm run test:unit -w @viewportai/daemon",
    "daemon:install:verify": "npm run verify:install -w @viewportai/daemon",
    "relay:test": "npm run test -w @viewportai/relay",
    "daemon:check": "npm run check -w @viewportai/daemon",
    "relay:check": "npm run check -w @viewportai/relay"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^24.2.9"
  },
  "overrides": {
    "@semantic-release/npm": {
      "npm": "^11.14.1"
    }
  }
}
