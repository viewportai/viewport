#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DAEMON_ENTRY="$ROOT/packages/daemon/dist/index.js"
NODE_BIN="${NODE_BIN:-$(command -v node)}"
PARENT="$(cd "$ROOT/.." && pwd)"

if [[ -d "$PARENT/platform" && -d "$PARENT/viewport" ]]; then
  PROJECT_CONFIG_DIR="${VIEWPORT_PROJECT_CONFIG_DIR:-$PARENT/.viewport}"
else
  PROJECT_CONFIG_DIR="${VIEWPORT_PROJECT_CONFIG_DIR:-$ROOT/.viewport}"
fi

mkdir -p "$PROJECT_CONFIG_DIR"

cd "$ROOT"

export VIEWPORT_PROJECT_CONFIG_DIR="$PROJECT_CONFIG_DIR"
export VPD_PROJECT_CONFIG_DIR="$VIEWPORT_PROJECT_CONFIG_DIR"
export VIEWPORT_RUNTIME_KIND="${VIEWPORT_RUNTIME_KIND:-local-dev}"

maybe_enable_project_tls() {
  [[ -n "${VIEWPORT_TLS:-}" ]] && return 0

  local config_path="$PROJECT_CONFIG_DIR/config.json"
  [[ -f "$config_path" ]] || return 0

  local tls_host=""
  tls_host="$("$NODE_BIN" -e '
    const fs = require("node:fs");
    const file = process.argv[1];
    try {
      const config = JSON.parse(fs.readFileSync(file, "utf8"));
      const daemon = config?.daemon ?? {};
      const urls = [daemon?.server?.url, daemon?.relay?.endpoint];
      const candidates = [];
      for (const value of urls) {
        if (typeof value !== "string" || value.length === 0) continue;
        try {
          const host = new URL(value).hostname;
          if (!host) continue;
          candidates.push(host);
          if (!host.startsWith("app.")) {
            candidates.push(`app.${host}`);
          }
        } catch {}
      }
      process.stdout.write(JSON.stringify(candidates));
    } catch {
      process.stdout.write("[]");
    }
  ' "$config_path")"

  local viewport_home="${VIEWPORT_HOME:-${VPD_HOME:-$HOME/.viewport}}"
  local project_cert_dir="$PROJECT_CONFIG_DIR/certs"
  local global_cert_dir="$viewport_home/certs"
  local candidate=""
  local global_cert=""
  local global_key=""
  local project_cert=""
  local project_key=""

  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    global_cert="$global_cert_dir/$candidate.crt"
    global_key="$global_cert_dir/$candidate.key"
    project_cert="$project_cert_dir/$candidate.crt"
    project_key="$project_cert_dir/$candidate.key"
    if [[ -f "$global_cert" && -f "$global_key" ]]; then
      tls_host="$candidate"
      break
    fi
    if [[ -f "$project_cert" && -f "$project_key" ]]; then
      mkdir -p "$global_cert_dir"
      install -m 600 "$project_cert" "$global_cert"
      install -m 600 "$project_key" "$global_key"
      tls_host="$candidate"
      break
    fi
  done < <("$NODE_BIN" -e '
    const raw = process.argv[1];
    try {
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) process.exit(0);
      for (const value of parsed) {
        if (typeof value === "string" && value.length > 0) {
          process.stdout.write(`${value}\n`);
        }
      }
    } catch {}
  ' "$tls_host")

  [[ -n "$tls_host" ]] || return 0

  export VIEWPORT_TLS=1
  export VIEWPORT_TLS_HOST="$tls_host"
  unset VIEWPORT_TLS_CERT_DIR
  unset VIEWPORT_TLS_CERT
  unset VIEWPORT_TLS_KEY
}

if [[ ! -f "$DAEMON_ENTRY" ]]; then
  npm run build -w @viewportai/daemon >/dev/null
fi

maybe_enable_project_tls

exec "$NODE_BIN" "$DAEMON_ENTRY" "$@"
