{
  "name": "@viewportai/workflow-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Plugin SDK for Viewport workflows. Define custom node types and JSONata expressions.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
