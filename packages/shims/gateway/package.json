{
  "name": "@viewportai/shim-gateway",
  "version": "0.1.0",
  "description": "Viewport GatewayProvider interface and reference adapters.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance/gateway-provider-conformance.d.ts",
      "import": "./dist/conformance/gateway-provider-conformance.js",
      "default": "./dist/conformance/gateway-provider-conformance.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
