{
  "name": "@viewportai/relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "start:prod": "node dist/index.js",
    "dev": "node --import ./scripts/load-env.mjs --import tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src tests --ext .ts --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "redis": "^4.7.1",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/ws": "^8.18.1",
    "eslint": "^9.20.0",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.2.4"
  }
}
