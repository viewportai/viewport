HOST=127.0.0.1
PORT=7781
SERVER_URL=https://api.getviewport.test
RELAY_PUBLIC_WS_BASE_URL=wss://getviewport.test:7781/ws
RELAY_TLS=auto
RELAY_TLS_HOST=getviewport.test
# Set this in .env.local when using Herd/Valet certificates.
# RELAY_TLS_CERT_DIR=/Users/YOUR_USER/Library/Application Support/Herd/config/valet/Certificates
RELAY_MODE=dev
RELAY_BACKPLANE_MODE=single
RELAY_ENABLE_ADMIN_HTTP=1
RELAY_ADMIN_TOKEN=dev-relay-admin-token
