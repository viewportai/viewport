{
  "name": "@viewportai/managed-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "start:prod": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test",
    "e2b:roundtrip": "tsx scripts/e2b-roundtrip.ts"
  },
  "dependencies": {
    "e2b": "^1.13.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
